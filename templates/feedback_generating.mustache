{{!
    @template assignfeedback_aif/feedback_generating

    Spinner shown while AI feedback is being generated in the background.

    Classes required for JS: none
    Data attributes required for JS: none
    Context variables required for this template:
    * none

    Example context (json):
    {}
}}
<div class="assignfeedback_aif-generating d-flex align-items-center py-2" data-aif="generating">
    <div class="spinner-border spinner-border-sm text-primary mr-2 me-2" role="status">
        <span class="sr-only visually-hidden">{{#str}} loading {{/str}}</span>
    </div>
    <span class="text-muted">{{#str}} feedbackgenerating, assignfeedback_aif {{/str}}</span>
</div>
