{{!
    @template assignfeedback_aif/error_with_retry

    Error notification with a retry button for failed AI feedback generation.

    Context variables required for this template:
    * errormsg - The error message to display.
    * assignmentid - The assignment instance ID.
    * userid - The user ID.
    * retrylabel - The label for the retry button.

    Example context (json):
    {
        "errormsg": "AI feedback generation failed: quota exceeded",
        "assignmentid": 42,
        "userid": 7,
        "retrylabel": "Retry"
    }
}}
<div class="alert alert-danger" role="alert">
    {{{errormsg}}}
</div>
<button type="button"
        class="btn btn-secondary btn-sm mt-1"
        data-action="retry-aif"
        data-assignmentid="{{assignmentid}}"
        data-userid="{{userid}}">
    {{retrylabel}}
</button>
